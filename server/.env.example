# ── AI Provider ──────────────────────────────────────────────────────
# Which LLM provider to use for generating Hindi legal applications.
#   "claude"   → Anthropic Claude (default)
#   "deepseek" → DeepSeek via Anthropic-compatible endpoint
AI_PROVIDER=claude

# ── API Keys ─────────────────────────────────────────────────────────
# Required when AI_PROVIDER=claude
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required when AI_PROVIDER=deepseek
# Get your key at: https://platform.deepseek.com/api_keys
# DeepSeek uses an Anthropic-compatible Messages API at:
#   https://api.deepseek.com/anthropic
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Cloud Vision API (for Aadhar OCR) ──────────────────────────
# Get your key at: https://console.cloud.google.com/apis/credentials
# (Enable the Vision API first: https://console.cloud.google.com/apis/library/vision.googleapis.com)
GOOGLE_VISION_API_KEY=your-vision-api-key-here

# ── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
